{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "color": {
    "$type": "color",
    "srgb-low": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.01, 0.02, 0.03],
        "alpha": 1
      },
      "$description": "sRGB with low values (below 0.04045 threshold)"
    },
    "a98-negative": {
      "$value": {
        "colorSpace": "a98-rgb",
        "components": [-0.1, 0.01, 0.5],
        "alpha": 1
      },
      "$description": "A98 RGB with negative component"
    },
    "prophoto-low": {
      "$value": {
        "colorSpace": "prophoto-rgb",
        "components": [0.02, 0.01, 0.03],
        "alpha": 1
      },
      "$description": "ProPhoto RGB with low values (below 16/512 threshold)"
    },
    "rec2020-low": {
      "$value": {
        "colorSpace": "rec2020",
        "components": [0.01, 0.02, 0.03],
        "alpha": 1
      },
      "$description": "Rec2020 with low values (below beta*4.5 threshold)"
    }
  }
}
