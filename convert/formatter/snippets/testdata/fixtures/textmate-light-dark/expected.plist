<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<array>
  <dict>
    <key>name</key>
    <string>color-text</string>
    <key>tabTrigger</key>
    <string>color-text</string>
    <key>content</key>
    <string>var(--color-text, light-dark(
  var(--color-text-light, #000000),
  var(--color-text-dark, #ffffff)
))</string>
    <key>scope</key>
    <string>source.css, source.scss</string>
  </dict>
</array>
</plist>
