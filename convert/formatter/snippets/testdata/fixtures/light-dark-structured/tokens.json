{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "color": {
    "$type": "color",
    "surface": {
      "$root": {
        "$value": {
          "$ref": "#/color/surface/light"
        }
      },
      "light": {
        "$value": {
          "colorSpace": "srgb",
          "hex": "#f5f5f5",
          "components": [0.96, 0.96, 0.96],
          "alpha": 1
        }
      },
      "dark": {
        "$value": {
          "colorSpace": "srgb",
          "hex": "#1a1a1a",
          "components": [0.1, 0.1, 0.1],
          "alpha": 1
        }
      }
    }
  }
}
