{
  "base": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [1, 0, 0],
        "alpha": 1.0,
        "hex": "#ff0000"
      },
      "$extensions": {
        "com.example.tags": ["brand", "primary"],
        "com.example.metadata": {
          "source": "figma",
          "version": 2,
          "nested": {
            "flag": true
          }
        }
      }
    }
  },
  "theme": {
    "$extends": "#/base",
    "$type": "color",
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0, 0, 1],
        "alpha": 1.0,
        "hex": "#0000ff"
      }
    }
  }
}
